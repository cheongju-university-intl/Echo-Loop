# 认证环境变量示例
#
# 复制为 auth.env（已在 .gitignore 中忽略），按需填入真实值。
# build 时通过 `flutter build/run --dart-define-from-file=auth.env` 注入。
#
# 凭据为空时 main.dart 跳过 Supabase 初始化，登录功能不可用但 app 仍可
# 匿名运行。开发期可保留为空跑通匿名流程。

# Supabase 项目 URL（如 https://xxx.supabase.co），见 fluency-frontend 的 .env.local
SUPABASE_URL=

# Supabase publishable key（公开 key，可前端暴露）
SUPABASE_PUBLISHABLE_KEY=

# Google OAuth Web Client ID，仅 Android 用作 serverClientId
# iOS / macOS 不接 Google，无需填
GOOGLE_WEB_CLIENT_ID=

# RevenueCat 公开 SDK API Key（订阅，按平台填；来源：RevenueCat → Project settings → API keys）
REVENUECAT_API_KEY_APPLE=
REVENUECAT_API_KEY_GOOGLE=
# Plus 会员的 entitlement 标识，需与 RevenueCat 后台一致，默认 Echo Loop Plus 可不填
REVENUECAT_ENTITLEMENT_ID=
